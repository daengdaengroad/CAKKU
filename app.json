{
  "expo": {
    "name": "carcare-agency",
    "slug": "carcare-agency",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "carcareagency",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "손상 부위를 촬영해서 AI 진단을 받기 위해 카메라 접근 권한이 필요해요.",
        "NSPhotoLibraryUsageDescription": "손상 사진을 선택해서 AI 진단을 받기 위해 사진 라이브러리 접근 권한이 필요해요.",
        "NSLocationWhenInUseUsageDescription": "주변 정비소를 찾기 위해 위치 접근 권한이 필요해요."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "손상 사진을 선택해서 AI 진단을 받기 위해 사진 라이브러리 접근 권한이 필요해요.",
          "cameraPermission": "손상 부위를 촬영해서 AI 진단을 받기 위해 카메라 접근 권한이 필요해요."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "주변 정비소를 찾기 위해 위치 접근 권한이 필요해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
